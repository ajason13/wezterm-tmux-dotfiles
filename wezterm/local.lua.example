-- Personal WezTerm overrides for THIS machine.
--
-- Copy this file to `local.lua` (same directory) to activate it. `local.lua` is
-- gitignored, so your machine-specific tweaks never touch the shared config:
--
--     cp local.lua.example local.lua
--
-- It is loaded LAST, after every module in modules/, so anything set here wins.
-- Return a table of override knobs (read by the modules) and/or an
-- `apply(config, wezterm, env)` function for arbitrary WezTerm settings.
-- Everything below is commented out; uncomment only what you want to change.

return {
  -- === Background knobs (see modules/backgrounds.lua) ===

  -- Dim / tint the rotating wallpaper. Lower brightness = darker image.
  -- (default: { brightness = 0.40, saturation = 0.90 })
  -- background_hsb = { brightness = 0.40, saturation = 0.90, hue = 1.0 },

  -- How often the wallpaper rotates, in seconds. (default: 15 minutes)
  -- background_rotation_seconds = 15 * 60,

  -- Temporarily exclude exact background paths from rotation without removing
  -- them from the shared manifest files.
  -- background_excludes = {
  --   '200-anime/haikyuu/014-pointing-black.png',
  -- },

  -- Opacity of the whole window against the desktop. Keep at 1.0 so the
  -- wallpaper fully replaces the desktop; below 1.0 makes the window see-through.
  -- Only applied when a wallpaper is active. (default: 1.0)
  -- window_background_opacity = 1.0,

  -- Opacity of cells with an EXPLICIT background color (full-screen TUIs such as
  -- editors or Claude Code, and styled tmux status segments). Lower = wallpaper
  -- shows through them too, at the cost of text contrast. (default: 0.55)
  -- text_background_opacity = 0.55,

  -- === Arbitrary overrides ===
  -- Runs last, so it can set or override ANY WezTerm option.
  -- apply = function(config, wezterm, env)
  --   config.font_size = 14.0
  --   config.color_scheme = 'Catppuccin Mocha'
  -- end,
}
